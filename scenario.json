{
  "scenario_id": "openai-agents-handoff.demo.v1",
  "title": "OpenAI Agents handoff with durable delivery",
  "description": "OpenAI agent processes a task via AXME durable intent lifecycle.",
  "agents": [
    {
      "role": "openai_agent",
      "address": "openai-agent-demo",
      "display_name": "OpenAI Processing Agent",
      "delivery_mode": "stream",
      "create_if_missing": true
    }
  ],
  "workflow": {
    "steps": [
      {
        "step_id": "process_task",
        "tool_id": "tool.agent.task.v1",
        "assigned_to": "openai_agent",
        "step_deadline_seconds": 120
      }
    ]
  },
  "intent": {
    "type": "intent.openai.task_processing.v1",
    "payload": {
      "task": "Analyze Q1 sales data and generate insights",
      "priority": "high",
      "department": "Sales"
    },
    "max_delivery_attempts": 3
  }
}
